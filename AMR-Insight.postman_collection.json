{
  "info": {
    "name": "AMR Insight",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Dashboard summary",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/dashboard/summary"
      }
    },
    {
      "name": "Susceptibility",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/dashboard/susceptibility?organism=Acinetobacter%20species"
      }
    },
    {
      "name": "Consumption yearly",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/dashboard/consumption-yearly"
      }
    },
    {
      "name": "Deployments",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/deployments"
      }
    }
  ]
}